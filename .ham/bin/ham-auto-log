#!/usr/bin/env bash
# ham-auto-log — extract token usage from agent logs and call ham.log with full metadata
# Runs as a platform hook (Stop, task-end, agentStop, AfterAgent)
# Then delegates to ham-verify for compliance check
# Generated by HAM Pro scaffold — do not edit manually

set -euo pipefail

HAM_DIR=".ham"
HAM_BIN_DIR="$HAM_DIR/bin"
MCP_CONFIG=".mcp.json"
CURSOR_MCP_CONFIG=".cursor/mcp.json"

# ── 1. Extract MCP endpoint URL and API key from config ──

get_mcp_config() {
  local config_file=""
  if [ -f "$MCP_CONFIG" ]; then
    config_file="$MCP_CONFIG"
  elif [ -f "$CURSOR_MCP_CONFIG" ]; then
    config_file="$CURSOR_MCP_CONFIG"
  else
    return 1
  fi

  # Extract URL and auth from MCP config using python3
  python3 << 'PYEOF'
import json, sys, os

config_file = sys.argv[1] if len(sys.argv) > 1 else os.environ.get("HAM_MCP_CONFIG", "")
if not config_file:
    for f in [".mcp.json", ".cursor/mcp.json"]:
        if os.path.exists(f):
            config_file = f
            break

if not config_file or not os.path.exists(config_file):
    print("ERROR:no_config")
    sys.exit(0)

try:
    with open(config_file) as f:
        config = json.load(f)
    server = config.get("mcpServers", {}).get("ham-memory", {})
    url = server.get("url", "")
    headers = server.get("headers", {})
    auth = headers.get("Authorization", "")
    if not url:
        print("ERROR:no_url")
        sys.exit(0)
    # Extract token from URL query param if no auth header (Cursor pattern)
    token = ""
    if auth.startswith("Bearer "):
        token = auth[7:]
    elif "?token=" in url:
        token = url.split("?token=")[1].split("&")[0]
    if not token:
        print("ERROR:no_token")
        sys.exit(0)
    # Strip query params from URL for the POST endpoint
    base_url = url.split("?")[0]
    print(f"URL:{base_url}")
    print(f"TOKEN:{token}")
except Exception as e:
    print(f"ERROR:{e}")
PYEOF
}

# ── 2. Agent-specific log parsers ──

# Each parser outputs: MODEL|AGENT|INPUT_TOKENS|OUTPUT_TOKENS|CACHE_READ|CACHE_WRITE

parse_claude_code_logs() {
  python3 << 'PYEOF'
import json, os, glob

# Encode project path: /Users/foo/project → -Users-foo-project
cwd = os.getcwd()
encoded = cwd.replace("/", "-")
claude_dir = os.path.expanduser(f"~/.claude/projects/{encoded}")

if not os.path.isdir(claude_dir):
    print("NONE")
    import sys; sys.exit(0)

# Find the most recently modified .jsonl file
jsonl_files = glob.glob(os.path.join(claude_dir, "*.jsonl"))
if not jsonl_files:
    print("NONE")
    import sys; sys.exit(0)

latest = max(jsonl_files, key=os.path.getmtime)

# Parse all assistant messages and sum tokens
total_input = 0
total_output = 0
total_cache_read = 0
total_cache_write = 0
model = "unknown"

try:
    with open(latest) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
            except json.JSONDecodeError:
                continue
            msg = entry.get("message", {})
            usage = msg.get("usage", {})
            if not usage:
                continue
            total_input += usage.get("input_tokens", 0)
            total_output += usage.get("output_tokens", 0)
            total_cache_read += usage.get("cache_read_input_tokens", 0)
            total_cache_write += usage.get("cache_creation_input_tokens", 0)
            m = msg.get("model", "")
            if m:
                model = m
except Exception:
    print("NONE")
    import sys; sys.exit(0)

if total_input == 0 and total_output == 0:
    print("NONE")
else:
    print(f"{model}|claude|{total_input}|{total_output}|{total_cache_read}|{total_cache_write}")
PYEOF
}

parse_cline_logs() {
  python3 << 'PYEOF'
import json, os, glob

# Cline stores task data in VS Code globalStorage
# Common paths: ~/.vscode/globalStorage/saoudrizwan.claude-dev/tasks/
#               ~/Library/Application Support/Code/User/globalStorage/saoudrizwan.claude-dev/tasks/
candidates = [
    os.path.expanduser("~/.vscode/globalStorage/saoudrizwan.claude-dev/tasks"),
    os.path.expanduser("~/Library/Application Support/Code/User/globalStorage/saoudrizwan.claude-dev/tasks"),
    os.path.expanduser("~/.vscode-server/data/User/globalStorage/saoudrizwan.claude-dev/tasks"),
]

tasks_dir = None
for c in candidates:
    if os.path.isdir(c):
        tasks_dir = c
        break

if not tasks_dir:
    print("NONE")
    import sys; sys.exit(0)

# Find the most recent task directory
task_dirs = [os.path.join(tasks_dir, d) for d in os.listdir(tasks_dir)
             if os.path.isdir(os.path.join(tasks_dir, d))]
if not task_dirs:
    print("NONE")
    import sys; sys.exit(0)

latest_task = max(task_dirs, key=os.path.getmtime)
api_log = os.path.join(latest_task, "api_conversation_history.json")

if not os.path.exists(api_log):
    print("NONE")
    import sys; sys.exit(0)

total_input = 0
total_output = 0
total_cache_read = 0
total_cache_write = 0
model = "unknown"

try:
    with open(api_log) as f:
        conversations = json.load(f)
    if not isinstance(conversations, list):
        conversations = [conversations]
    for msg in conversations:
        usage = msg.get("usage", {})
        if usage:
            total_input += usage.get("input_tokens", 0)
            total_output += usage.get("output_tokens", 0)
            total_cache_read += usage.get("cache_read_input_tokens", 0)
            total_cache_write += usage.get("cache_creation_input_tokens", 0)
        m = msg.get("model", "")
        if m:
            model = m
except Exception:
    print("NONE")
    import sys; sys.exit(0)

if total_input == 0 and total_output == 0:
    print("NONE")
else:
    print(f"{model}|cline|{total_input}|{total_output}|{total_cache_read}|{total_cache_write}")
PYEOF
}

parse_copilot_logs() {
  python3 << 'PYEOF'
import json, os, glob

# GitHub Copilot CLI writes session logs to ~/.copilot/ or extension storage
candidates = [
    os.path.expanduser("~/.copilot"),
    os.path.expanduser("~/Library/Application Support/Code/User/globalStorage/github.copilot-chat"),
    os.path.expanduser("~/.vscode/globalStorage/github.copilot-chat"),
]

log_dir = None
for c in candidates:
    if os.path.isdir(c):
        log_dir = c
        break

if not log_dir:
    print("NONE")
    import sys; sys.exit(0)

# Look for the most recent .jsonl session file
jsonl_files = glob.glob(os.path.join(log_dir, "**", "*.jsonl"), recursive=True)
if not jsonl_files:
    # Also check for JSON conversation files
    json_files = glob.glob(os.path.join(log_dir, "**", "*.json"), recursive=True)
    jsonl_files = json_files

if not jsonl_files:
    print("NONE")
    import sys; sys.exit(0)

latest = max(jsonl_files, key=os.path.getmtime)

total_input = 0
total_output = 0
model = "unknown"

try:
    with open(latest) as f:
        content = f.read().strip()
    # Try JSONL first
    for line in content.split("\n"):
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        usage = entry.get("usage", entry.get("token_usage", {}))
        if isinstance(usage, dict):
            total_input += usage.get("prompt_tokens", usage.get("input_tokens", 0))
            total_output += usage.get("completion_tokens", usage.get("output_tokens", 0))
        m = entry.get("model", "")
        if m:
            model = m
except Exception:
    print("NONE")
    import sys; sys.exit(0)

if total_input == 0 and total_output == 0:
    print("NONE")
else:
    print(f"{model}|copilot|{total_input}|{total_output}|0|0")
PYEOF
}

parse_gemini_logs() {
  python3 << 'PYEOF'
import json, os, glob

# Gemini CLI stores session data in ~/.gemini/
candidates = [
    os.path.expanduser("~/.gemini"),
    os.path.expanduser("~/.config/gemini"),
]

log_dir = None
for c in candidates:
    if os.path.isdir(c):
        log_dir = c
        break

if not log_dir:
    print("NONE")
    import sys; sys.exit(0)

# Gemini API responses include usageMetadata with token counts
jsonl_files = glob.glob(os.path.join(log_dir, "**", "*.jsonl"), recursive=True)
json_files = glob.glob(os.path.join(log_dir, "**", "*.json"), recursive=True)
all_files = jsonl_files + json_files

if not all_files:
    print("NONE")
    import sys; sys.exit(0)

latest = max(all_files, key=os.path.getmtime)

total_input = 0
total_output = 0
model = "unknown"

try:
    with open(latest) as f:
        content = f.read().strip()
    for line in content.split("\n"):
        if not line.strip():
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        # Gemini API format: usageMetadata.promptTokenCount, candidatesTokenCount
        usage = entry.get("usageMetadata", {})
        if usage:
            total_input += usage.get("promptTokenCount", 0)
            total_output += usage.get("candidatesTokenCount", 0)
        # Also check nested response format
        for candidate in entry.get("candidates", []):
            u = candidate.get("usageMetadata", {})
            if u:
                total_input += u.get("promptTokenCount", 0)
                total_output += u.get("candidatesTokenCount", 0)
        m = entry.get("model", entry.get("modelVersion", ""))
        if m:
            model = m
except Exception:
    print("NONE")
    import sys; sys.exit(0)

if total_input == 0 and total_output == 0:
    print("NONE")
else:
    print(f"{model}|gemini|{total_input}|{total_output}|0|0")
PYEOF
}

# ── 3. Detect agent and parse logs ──

detect_and_parse() {
  local result=""

  # Try each parser in order of likelihood
  result=$(parse_claude_code_logs)
  if [ "$result" != "NONE" ] && [ -n "$result" ]; then
    echo "$result"
    return 0
  fi

  result=$(parse_cline_logs)
  if [ "$result" != "NONE" ] && [ -n "$result" ]; then
    echo "$result"
    return 0
  fi

  result=$(parse_copilot_logs)
  if [ "$result" != "NONE" ] && [ -n "$result" ]; then
    echo "$result"
    return 0
  fi

  result=$(parse_gemini_logs)
  if [ "$result" != "NONE" ] && [ -n "$result" ]; then
    echo "$result"
    return 0
  fi

  echo "NONE"
  return 0
}

# ── 4. Call ham.log via MCP HTTP endpoint ──

call_ham_log() {
  local mcp_url="$1"
  local token="$2"
  local model="$3"
  local agent="$4"
  local input_tokens="$5"
  local output_tokens="$6"

  # Read the most recent ham.log trace to get summary + files_changed
  # (the agent already called ham.log — we just need to enrich it with token data)
  # If no trace exists yet, skip — ham-verify will catch it
  local traces_dir=".ham/traces"

  if [ ! -d "$traces_dir" ]; then
    return 0
  fi

  # Build JSON-RPC body for ham.log
  local body=$(python3 << PYEOF
import json
body = {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {
        "name": "ham.log",
        "arguments": {
            "summary": "[auto-enriched] Token usage from $agent session",
            "files_changed": [],
            "agent": "$agent",
            "model": "$model",
            "input_tokens": $input_tokens,
            "output_tokens": $output_tokens
        }
    }
}
print(json.dumps(body))
PYEOF
  )

  # POST to MCP endpoint
  curl -s -X POST "$mcp_url" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $token" \
    -d "$body" > /dev/null 2>&1 || true
}

# ── 5. Main ──

# Parse MCP config
MCP_INFO=$(get_mcp_config 2>/dev/null || echo "ERROR:no_config")
MCP_URL=""
MCP_TOKEN=""

while IFS= read -r line; do
  case "$line" in
    URL:*) MCP_URL="${line#URL:}" ;;
    TOKEN:*) MCP_TOKEN="${line#TOKEN:}" ;;
  esac
done <<< "$MCP_INFO"

# Detect agent and extract token data
AGENT_DATA=$(detect_and_parse 2>/dev/null || echo "NONE")

if [ "$AGENT_DATA" != "NONE" ] && [ -n "$MCP_URL" ] && [ -n "$MCP_TOKEN" ]; then
  IFS="|" read -r MODEL AGENT INPUT_TOKENS OUTPUT_TOKENS CACHE_READ CACHE_WRITE <<< "$AGENT_DATA"
  echo "ham-auto-log: detected $AGENT agent | model=$MODEL | in=$INPUT_TOKENS out=$OUTPUT_TOKENS cache_read=$CACHE_READ cache_write=$CACHE_WRITE"
  call_ham_log "$MCP_URL" "$MCP_TOKEN" "$MODEL" "$AGENT" "$INPUT_TOKENS" "$OUTPUT_TOKENS"
else
  if [ "$AGENT_DATA" = "NONE" ]; then
    echo "ham-auto-log: no agent logs found — skipping token enrichment"
  else
    echo "ham-auto-log: no MCP config found — skipping token enrichment"
  fi
fi

# Always run ham-verify for compliance check
if [ -x "$HAM_BIN_DIR/ham-verify" ]; then
  exec "$HAM_BIN_DIR/ham-verify"
fi
