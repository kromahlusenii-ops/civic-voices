#!/usr/bin/env bash
# ham-verify — validate that the agent called ham.log before completing work
# Exit 0 = compliant, Exit 1 = non-compliant
# Generated by HAM Pro scaffold — do not edit manually

set -euo pipefail

HAM_TRACES_DIR=".ham/traces"

if [ ! -d "$HAM_TRACES_DIR" ]; then
  echo "ham-verify: FAIL — no .ham/traces/ directory found"
  echo "The agent must call ham.log before completing work."
  exit 1
fi

# Find the most recent .jsonl file (macOS + Linux compatible)
if stat --version &>/dev/null 2>&1; then
  # GNU stat (Linux)
  LATEST=$(find "$HAM_TRACES_DIR" -name "*.jsonl" -type f -exec stat -c '%Y %n' {} + 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)
else
  # BSD stat (macOS)
  LATEST=$(find "$HAM_TRACES_DIR" -name "*.jsonl" -type f -exec stat -f '%m %N' {} + 2>/dev/null | sort -rn | head -1 | awk '{print $2}')
fi

if [ -z "${LATEST:-}" ]; then
  echo "ham-verify: FAIL — no trace files found in .ham/traces/"
  echo "The agent must call ham.log before completing work."
  exit 1
fi

# Validate the trace using python3
export HAM_LATEST_TRACE="$LATEST"
RESULT=$(python3 << 'PYEOF'
import json, sys, os

latest = os.environ.get("HAM_LATEST_TRACE", "")
if not latest:
    print("FAIL:no trace file")
    sys.exit(0)

try:
    with open(latest, "r") as f:
        lines = [l.strip() for l in f if l.strip()]
    if not lines:
        print("FAIL:no trace entries found")
        sys.exit(0)
    data = json.loads(lines[-1])
    outputs = data.get("outputs", [])
    if not outputs:
        print("FAIL:no outputs in trace")
        sys.exit(0)
    summary = outputs[0].get("summary", "")
    files_changed = outputs[0].get("files_changed", [])
    if not summary:
        print("FAIL:summary is empty")
        sys.exit(0)
    if not files_changed:
        print("WARN:files_changed is empty")
        sys.exit(0)
    print("PASS")
except Exception as e:
    print("FAIL:parse error: {}".format(e))
PYEOF
)

case "$RESULT" in
  PASS)
    echo "ham-verify: PASS — valid ham.log trace found"
    exit 0
    ;;
  WARN:*)
    echo "ham-verify: WARN — ${RESULT#WARN:}"
    echo "Trace exists but files_changed is empty. Consider updating your ham.log call."
    exit 0
    ;;
  FAIL:*)
    echo "ham-verify: FAIL — ${RESULT#FAIL:}"
    echo "The agent must call ham.log before completing work."
    exit 1
    ;;
  *)
    echo "ham-verify: FAIL — unexpected result: $RESULT"
    exit 1
    ;;
esac
